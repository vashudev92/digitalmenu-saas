datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  OWNER
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  CANCELLED
}

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  passwordHash  String
  name          String
  role          Role        @default(OWNER)
  restaurant    Restaurant?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Restaurant {
  id             String         @id @default(uuid())
  name           String
  slug           String         @unique
  tagline        String?
  description    String?
  address        String?
  phone          String?
  whatsApp       String?
  website        String?
  googleMapsUrl  String?
  logo           String?        // URL to logo
  banner         String?        // URL to banner image
  theme          String         @default("LUXURY_DARK")
  currencySymbol String         @default("₹")
  fontHeading    String?        @default("Playfair Display")
  fontBody       String?        @default("Inter")
  primaryColor   String?        // Custom primary hex color
  secondaryColor String?        // Custom secondary hex color
  accentColor    String?        // Custom accent hex color
  favicon        String?        // URL to favicon image
  openingHours   String?        @default("11:00 AM - 11:00 PM")
  bannerTitle1   String?        @default("Good Food")
  bannerTitle2   String?        @default("Great Mood")
  bannerSubtitle String?        @default("Discover our chef's special selection just for you.")
  badge1Title    String?        @default("Hygienic")
  badge1Desc     String?        @default("Kitchen")
  badge2Title    String?        @default("Fresh")
  badge2Desc     String?        @default("Ingredients")
  badge3Title    String?        @default("Chef")
  badge3Desc     String?        @default("Specials")
  ownerId        String         @unique
  owner          User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  categories     Category[]
  menuItems      MenuItem[]
  menuProfiles   MenuProfile[]
  qrCodes        QRCode[]
  subscription   Subscription?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model MenuProfile {
  id             String      @id @default(uuid())
  name           String
  slug           String
  description    String?
  theme          String?     // Override restaurant theme (null = use restaurant default)
  primaryColor   String?     // Override restaurant color
  secondaryColor String?
  accentColor    String?
  fontHeading    String?     // Override restaurant font
  fontBody       String?
  bannerImage    String?     // Profile-specific banner
  logoOverride   String?     // Optional logo override
  openingHours   String?     // Profile-specific hours
  status         Boolean     @default(true)
  restaurantId   String
  restaurant     Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categories     Category[]
  menuItems      MenuItem[]
  qrCode         QRCode?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([restaurantId, slug])
}

model Category {
  id            String       @id @default(uuid())
  name          String
  icon          String       @default("Utensils") // Lucide icon name
  sortOrder     Int          @default(0)
  status        Boolean      @default(true) // Active/Inactive
  restaurantId  String
  restaurant    Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuProfileId String?
  menuProfile   MenuProfile? @relation(fields: [menuProfileId], references: [id], onDelete: SetNull)
  menuItems     MenuItem[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([restaurantId, name])
}

model MenuItem {
  id            String       @id @default(uuid())
  name          String
  description   String?
  price         Float
  image         String?      // URL to dish image
  isVeg         Boolean      @default(true)
  isFeatured    Boolean      @default(false)
  isAvailable   Boolean      @default(true)
  categoryId    String
  category      Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  restaurantId  String
  restaurant    Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuProfileId String?
  menuProfile   MenuProfile? @relation(fields: [menuProfileId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model QRCode {
  id            String       @id @default(uuid())
  url           String       // e.g. scanplate.com/r/slug/profile-slug
  dataUrl       String       @db.Text // Base64 image
  restaurantId  String
  restaurant    Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuProfileId String?      @unique
  menuProfile   MenuProfile? @relation(fields: [menuProfileId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Plan {
  id            String         @id @default(uuid())
  name          String         @unique // e.g. Free, Premium, Luxury
  price         Float
  description   String?
  features      String[]       // List of features
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Subscription {
  id           String             @id @default(uuid())
  status       SubscriptionStatus @default(TRIAL)
  restaurantId String             @unique
  restaurant   Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  planId       String
  plan         Plan               @relation(fields: [planId], references: [id])
  startDate    DateTime           @default(now())
  endDate      DateTime
  createdAt    DateTime           @default(now())
  updatedAt    DateTime       @updatedAt
}
